rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // userIndex: only the user themselves can read their own entry.
    // Only written by the owner client when creating a monitor.
    match /userIndex/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }

    // Owner document: only the owner can read/write their own profile
    match /owners/{ownerId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;

      // Subcollections (consoles, sessions, players, pricing, expenses):
      // Accessible by the owner themselves OR any monitor who belongs to this owner.
      match /{collection}/{docId} {
        allow read, write: if request.auth != null && (
          // Owner accessing their own data
          request.auth.uid == ownerId
          ||
          // Monitor: they have a userIndex entry pointing to this ownerId
          (exists(/databases/$(database)/documents/userIndex/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/userIndex/$(request.auth.uid)).data.ownerId == ownerId)
        );
      }

      // users subcollection (monitor accounts list) — owner only
      match /users/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == ownerId;
      }
    }
  }
}
