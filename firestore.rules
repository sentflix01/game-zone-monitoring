rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // userIndex: only the user themselves can read their own entry.
    // Owners can write entries for monitors they create (direct fallback path).
    // Cloud Functions also write here via admin SDK.
    match /userIndex/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Allow any authenticated user to create/update a userIndex entry
      // (owner creating a monitor entry, or monitor updating their own)
      allow write: if request.auth != null;
    }

    // monitorCredentials: contains bcrypt hashes — server-side only.
    // Cloud Functions use the admin SDK and bypass these rules entirely.
    match /monitorCredentials/{emailKey} {
      allow read, write: if false;
    }

    // Owner document: only the owner can read/write their own profile
    match /owners/{ownerId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;

      // Subcollections (consoles, sessions, players, pricing, expenses):
      // Accessible by the owner themselves OR any monitor who belongs to this owner.
      match /{collection}/{docId} {
        allow read, write: if request.auth != null && (
          // Owner accessing their own data
          request.auth.uid == ownerId
          ||
          // Monitor via userIndex entry
          (exists(/databases/$(database)/documents/userIndex/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/userIndex/$(request.auth.uid)).data.ownerId == ownerId)
          ||
          // Dual-role monitor via custom token claims
          (request.auth.token.get('role', '') == 'monitor' &&
           request.auth.token.get('ownerId', '') == ownerId)
        );
      }

      // users subcollection (monitor accounts list) — owner only
      match /users/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == ownerId;
      }

      // notifications subcollection — owner can read and mark as read (update)
      // Only Cloud Functions write new notifications
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == ownerId;
        allow update: if request.auth != null && request.auth.uid == ownerId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false; // Cloud Functions only
      }
    }
  }
}
